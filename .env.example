# Admin seed script (not needed at runtime)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Superadmin (email-based privilege in admin panel)
SUPERADMIN_EMAIL=

# Public (client) API URLs - prefix with NEXT_PUBLIC_
